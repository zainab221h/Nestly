<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <body>
      <br /><br />
      <h3>Create new listing</h3>

      <form method="post" action="/listings">
        <div class="mb-3">
          <lable for="title" class="form-label">Title</lable>
          <input
            name="listing[title]"
            placeholder="enter a catchy title "
            type="text"
            class="form-control"
          />
        </div>
        <div class="mb-3">
          <lable for="description" class="form-label">Description</lable>
          <textarea name="listing[description]" class="form-control"></textarea>
        </div>
        <div class="mb-3">
          <lable for="image" class="form-label">Image</lable>
          <input
            type="text"
            name="listing[image]"
            placeholder="enter image URL"
            class="form-control"
          />
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input
              name="listing[price]"
              placeholder="1900"
              type="number"
              class="form-control"
            />
          </div>

          <div class="mb-3 col-md-8">
            <lable for="location" class="form-label">Location</lable>
            <input
              type="text"
              name="listing[location]"
              placeholder="enter the location"
              class="form-control"
            />
          </div>
        </div>

        <div class="mb-3">
          <lable for="country" class="form-label">Country</lable>
          <input
            type="text"
            name="listing[country]"
            placeholder="enter the country"
            class="form-control"
          />
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
      </form>
    </body>
  </div>
</div>
