<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <body>
      <br /><br />
      <h3>Create new listing</h3>

      <form
        method="post"
        action="/listings"
        novalidate
        class="needs-validation"
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <lable for="title" class="form-label">Title</lable>
          <input
            name="listing[title]"
            placeholder="enter a catchy title "
            type="text"
            class="form-control"
            required
          />
          <div class="valid-feedback">Title Looks Good!</div>
          <div class="invalid-feedback">Please Enter The Title</div>
        </div>
        <div class="mb-3">
          <lable for="description" class="form-label">Description</lable>
          <button
            type="button"
            id="generateBtn"
            class="btn btn-outline-success btn-sm mb-2"
          >
            ✨ Generate Description with AI
          </button>
          <textarea
            name="listing[description]"
            class="form-control"
            required
          ></textarea>
          <div class="valid-feedback">Description Looks Good!</div>
          <div class="invalid-feedback">Please Enter The Description</div>
        </div>
        <div class="mb-3">
          <lable for="image" class="form-label">Image</lable>
          <input type="file" name="listing[image]" class="form-control" />
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input
              name="listing[price]"
              placeholder="1900"
              class="form-control"
              required
            />
            <div class="valid-feedback">Price Looks Good!</div>
            <div class="invalid-feedback">Please Enter The Price</div>
          </div>

          <div class="mb-3 col-md-8">
            <lable for="location" class="form-label">Location</lable>
            <input
              type="text"
              name="listing[location]"
              placeholder="enter the location"
              class="form-control"
              required
            />
            <div class="valid-feedback">Location Looks Good!</div>
            <div class="invalid-feedback">Please Enter The Location</div>
          </div>
        </div>

        <div class="mb-3">
          <lable for="country" class="form-label">Country</lable>
          <input
            type="text"
            name="listing[country]"
            placeholder="enter the country"
            class="form-control"
            required
          />
          <div class="valid-feedback">Country Looks Good!</div>
          <div class="invalid-feedback">Please Enter The Country</div>
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
      </form>
      <script>
        document
          .getElementById("generateBtn")
          .addEventListener("click", async () => {
            const title = document.querySelector(
              '[name="listing[title]"]'
            ).value;
            const location = document.querySelector(
              '[name="listing[location]"]'
            ).value;
            const country = document.querySelector(
              '[name="listing[country]"]'
            ).value;

            if (!title || !location || !country) {
              alert("Pehle title, location aur country bhar do");
              return;
            }

            const btn = document.getElementById("generateBtn");
            const originalText = btn.textContent;
            btn.textContent = "Generating...";
            btn.disabled = true;

            try {
              const res = await fetch("/listings/generate-description", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ title, location, country }),
              });
              const data = await res.json();
              document.querySelector('[name="listing[description]"]').value =
                data.description;
            } catch (err) {
              alert("Description generate nahi ho payi, dobara try karo");
            } finally {
              btn.textContent = originalText;
              btn.disabled = false;
            }
          });
      </script>
    </body>
  </div>
</div>
