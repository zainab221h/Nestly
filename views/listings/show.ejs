<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-3 mt-3">
    <h3>Listing Details</h3>
  </div>
  <div class="card col-6 offset-3 show-card">
    <img
      src="<%= foundListing.image.url %>"
      class="card-img-top show-img"
      alt="<%=
        foundListing.image.filename %>"
    />
    <div class="card-body">
      <p class="card-text">
        <b><%= foundListing.title %> </b> <br />
        <%= foundListing.description %> <br />
        &#8377; <%= foundListing.price.toLocaleString("en-IN") %> <br />
        <%= foundListing.location %> <br />
        <%= foundListing.country %>
      </p>
    </div>
  </div>
  <br />
</div>
<div class="btns">
  <a
    href="/listings/<%= foundListing._id %>/edit"
    class="btn btn-dark col-1 offset-3 edit-btn"
    >Edit
  </a>
  <form method="post" action="/listings/<%= foundListing._id %>?_method=Delete">
    <button class="btn btn-dark offset-6">Delete</button>
  </form>
</div>
